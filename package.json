{
  "name": "dm-forge",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run --project='unit:*'",
    "test:unit": "vitest run --project='unit:*'",
    "test:integration": "pnpm --filter @dm-forge/tests test",
    "test:all": "pnpm test:unit && pnpm test:integration",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --project='unit:*'",
    "gen:secrets": "node scripts/gen-secrets.mjs",
    "db:migrate": "pnpm --filter @dm-forge/db exec prisma migrate",
    "db:studio": "pnpm --filter @dm-forge/db exec prisma studio",
    "db:seed": "pnpm --filter @dm-forge/db exec tsx src/seed.ts",
    "db:reset": "pnpm --filter @dm-forge/db exec prisma migrate reset",
    "db:generate": "pnpm --filter @dm-forge/db exec prisma generate",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "pnpm": {
    "overrides": {
      "kysely": "0.28.17"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "^3.2.4",
    "prisma": "catalog:",
    "tsx": "catalog:",
    "turbo": "^2.9.15",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod-prisma-types": "catalog:"
  }
}
