{
  "name": "@dm-forge/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "build": "prisma generate",
    "typecheck": "tsc --noEmit",
    "test": "pnpm -w exec vitest run --project='unit:db'",
    "seed": "tsx src/seed.ts",
    "clean": "rm -rf .turbo coverage src/generated"
  },
  "dependencies": {
    "@dm-forge/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "prisma": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod-prisma-types": "catalog:"
  }
}
