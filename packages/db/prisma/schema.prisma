// Prisma schema — source of truth for the dm-forge database.
//
// Required conventions (see `.ai/constitution.md` and `docs/coding-patterns.md`):
//  * IDs are generated client-side with cuid2 — never use `@default(cuid())`.
//  * Campaign entities carry `state EntityState @default(ACTIVE)` for soft delete.
//  * Auth tables (User, Session, Account, Verification) follow the Better Auth contract.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

generator zod {
  provider                = "zod-prisma-types"
  output                  = "../src/generated/zod"
  createInputTypes        = false
  createRelationValuesTypes = false
  addIncludeType          = false
  addSelectType           = false
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EntityState {
  ACTIVE
  DELETED
}

// ─── Better Auth (email + password) ─────────────────────────────────────────
// Field names follow the contract expected by Better Auth. Do not rename
// without revisiting the Better Auth configuration in apps/api.

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  locale        String   @default("pt-BR")
  accountStatus String   @default("active")
  pendingDeletionAt DateTime?
  acceptedTermsVersion String?
  acceptedPrivacyVersion String?
  telemetryConsent Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions      Session[]
  accounts      Account[]
  aiConnections AiConnection[]
  campaigns     Campaign[]
  consentRecords ConsentRecord[]
  dataExportRequests DataExportRequest[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ─── dm-forge domain ───────────────────────────────────────────────────────

model AiConnection {
  id           String @id
  userId       String
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // LLM provider (for now only "openrouter").
  provider     String
  label        String

  // BYOK key encrypted with AES-256-GCM. Never decrypt outside the request
  // that will use it (see docs/architecture-overview.md → BYOK).
  encryptedKey Bytes
  iv           Bytes
  authTag      Bytes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("ai_connection")
}

model Campaign {
  id          String      @id
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  state       EntityState @default(ACTIVE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId, state])
  @@map("campaign")
}

model ConsentRecord {
  id         String   @id
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  action     String
  version    String
  occurredAt DateTime @default(now())
  ipPrefix   String?
  userAgent  String?

  @@index([userId, type, occurredAt(sort: Desc)])
  @@map("consent_record")
}

model DataExportRequest {
  id                String   @id
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status            String
  requestedAt       DateTime @default(now())
  readyAt           DateTime?
  expiresAt         DateTime?
  payload           Json?
  downloadTokenHash String?

  @@index([userId, requestedAt(sort: Desc)])
  @@map("data_export_request")
}

model LoginAttempt {
  id             String   @id
  ipEmailKey     String   @unique
  firstAttemptAt DateTime
  attemptCount   Int
  blockedUntil   DateTime?

  @@map("login_attempt")
}

model AccountDeletionAudit {
  id         String   @id
  userIdHash String
  deletedAt  DateTime @default(now())

  @@index([deletedAt(sort: Desc)])
  @@map("account_deletion_audit")
}
