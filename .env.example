# ───────────────────────────────────────────────────────────────────────────
# dm-forge — variáveis de ambiente
# Copie este arquivo para `.env` e preencha. Segredos NUNCA vão para o repo.
# ───────────────────────────────────────────────────────────────────────────

# Modo de execução. Aceita: development | test | production.
NODE_ENV=development

# ─── Banco de dados ────────────────────────────────────────────────────────
# Credenciais consumidas pelo docker-compose E expandidas em DATABASE_URL.
# Mantenha um único lugar de verdade: muda aqui, replica em todo lado.
POSTGRES_USER=dmforge
POSTGRES_PASSWORD=dmforge
POSTGRES_DB=dmforge
POSTGRES_PORT=5432

DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public

# ─── apps/api ──────────────────────────────────────────────────────────────
API_PORT=3000
WEB_ORIGIN=http://localhost:5173

# Better Auth: segredo de assinatura de sessão (>= 32 caracteres).
# Gere com: openssl rand -base64 48
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Chave-mestra AES-256-GCM para criptografar BYOK (32 bytes em base64).
# Gere com: openssl rand -base64 32
ENCRYPTION_KEY=

# ─── E-mail transacional (ADR 0007) ────────────────────────────────────────
# Provider de envio de e-mails de autenticação (verificação, reset, etc.).
# Aceita: noop | resend. Use `noop` em dev/test (loga só o tipo, não envia).
EMAIL_PROVIDER=noop

# Obrigatórios quando EMAIL_PROVIDER=resend. Boot falha se faltarem.
# API key: https://resend.com/api-keys  |  Remetente de domínio verificado.
RESEND_API_KEY=
EMAIL_FROM="DM Forge <no-reply@dmforge.com>"

# ─── OAuth social providers (ADR 0003) ─────────────────────────────────────
# Login social Google/GitHub. Deixe vazio para desabilitar um provider — ele
# só é registrado no Better Auth quando id E secret estão preenchidos. Boot
# falha se preencher só metade de um par.
# Callback (registre no console do provider): ${BETTER_AUTH_URL}/api/auth/callback/<provider>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── apps/web ──────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000

# ─── Integrações com agentes (MCP) ─────────────────────────────────────────
# Estas variáveis alimentam os MCP servers configurados em .ai/mcp.json.
NOTION_TOKEN=
CONTEXT7_API_KEY=
GITHUB_PERSONAL_ACCESS_TOKEN=
