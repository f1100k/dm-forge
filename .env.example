# ───────────────────────────────────────────────────────────────────────────
# dm-forge — variáveis de ambiente
# Copie este arquivo para `.env` e preencha. Segredos NUNCA vão para o repo.
# ───────────────────────────────────────────────────────────────────────────

# Modo de execução. Aceita: development | test | production.
NODE_ENV=development

# ─── Banco de dados ────────────────────────────────────────────────────────
# Postgres local via docker-compose: vide README. Trocar usuário/senha em prod.
DATABASE_URL=postgresql://dmforge:dmforge@localhost:5432/dmforge?schema=public

# ─── apps/api ──────────────────────────────────────────────────────────────
API_PORT=3000
WEB_ORIGIN=http://localhost:5173

# Better Auth: segredo de assinatura de sessão (>= 32 caracteres).
# Gere com: openssl rand -base64 48
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Chave-mestra AES-256-GCM para criptografar BYOK (32 bytes em base64).
# Gere com: openssl rand -base64 32
ENCRYPTION_KEY=

# ─── apps/web ──────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000

# ─── Integrações com agentes (MCP) ─────────────────────────────────────────
# Estas variáveis alimentam os MCP servers configurados em .ai/mcp.json.
NOTION_TOKEN=
CONTEXT7_API_KEY=
GITHUB_PERSONAL_ACCESS_TOKEN=
